# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your-discord-bot-token

# Optional: restrict slash command sync to a single guild for instant updates.
# Leave blank to sync globally (takes up to ~1 hour to propagate).
DISCORD_GUILD_ID=

# Plex server connection. Use either a direct URL + token, OR a my.plex.tv account.
# Direct (preferred for self-hosted / LAN):
PLEX_BASE_URL=http://192.168.1.10:32400
PLEX_TOKEN=your-plex-token

# Account-based fallback (if PLEX_BASE_URL/PLEX_TOKEN not set):
# PLEX_USERNAME=
# PLEX_PASSWORD=
# PLEX_SERVER_NAME=

# Name of the music library section in Plex (case-sensitive)
PLEX_MUSIC_SECTION=Music
